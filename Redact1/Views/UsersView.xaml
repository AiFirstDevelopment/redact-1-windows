<UserControl x:Class="Redact1.Views.UsersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="clr-namespace:Redact1.Converters"
             mc:Ignorable="d"
             Background="{StaticResource BackgroundBrush}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Text="Users"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}" />

            <Button Grid.Column="1"
                    Content="+ Add User"
                    Style="{StaticResource PrimaryButton}"
                    Command="{Binding StartCreateUserCommand}" />
        </Grid>

        <!-- Users List -->
        <ScrollViewer Grid.Row="1">
            <ItemsControl ItemsSource="{Binding Users}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="{Binding Name}"
                                               FontWeight="SemiBold"
                                               FontSize="16" />
                                    <TextBlock Text="{Binding Email}"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Margin="0,4,0,0" />
                                    <Border Margin="0,8,0,0"
                                            Padding="8,4"
                                            CornerRadius="4"
                                            Background="{StaticResource BackgroundBrush}"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding Role}"
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}" />
                                    </Border>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Content="Edit"
                                            Style="{StaticResource SecondaryButton}"
                                            Command="{Binding DataContext.StartEditUserCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Margin="0,0,8,0" />
                                    <Button Content="Delete"
                                            Style="{StaticResource DangerButton}"
                                            Command="{Binding DataContext.DeleteUserCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Edit Dialog Overlay -->
        <Border Grid.RowSpan="2"
                Background="#80000000"
                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Background="{StaticResource SurfaceBrush}"
                    Style="{StaticResource Card}"
                    Width="400"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="User Details"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,0,20" />

                    <TextBlock Text="Name" FontWeight="Medium" Margin="0,0,0,8" />
                    <TextBox Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModernTextBox}"
                             Margin="0,0,0,16" />

                    <TextBlock Text="Email" FontWeight="Medium" Margin="0,0,0,8" />
                    <TextBox Text="{Binding EditEmail, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModernTextBox}"
                             Margin="0,0,0,16" />

                    <TextBlock Text="Role" FontWeight="Medium" Margin="0,0,0,8" />
                    <ComboBox SelectedValue="{Binding EditRole}"
                              SelectedValuePath="Tag"
                              Style="{StaticResource ModernComboBox}"
                              Margin="0,0,0,16">
                        <ComboBoxItem Content="Clerk" Tag="clerk" />
                        <ComboBoxItem Content="Supervisor" Tag="supervisor" />
                    </ComboBox>

                    <TextBlock Text="Password (leave blank to keep current)"
                               FontWeight="Medium"
                               Margin="0,0,0,8" />
                    <PasswordBox x:Name="EditPasswordBox"
                                 Style="{StaticResource ModernPasswordBox}"
                                 PasswordChanged="EditPasswordBox_PasswordChanged"
                                 Margin="0,0,0,24" />

                    <!-- Error Message -->
                    <Border Background="#FED7D7"
                            CornerRadius="6"
                            Padding="12"
                            Margin="0,0,0,16"
                            Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}">
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="#C53030"
                                   TextWrapping="Wrap" />
                    </Border>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Content="Cancel"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding CancelEditCommand}"
                                Margin="0,0,8,0" />

                        <Button Grid.Column="1"
                                Content="Save"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding SaveUserCommand}"
                                Margin="8,0,0,0" />
                    </Grid>
                </StackPanel>
            </Border>
        </Border>

        <!-- Loading -->
        <Border Grid.RowSpan="2"
                Background="#80FFFFFF"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <ProgressBar IsIndeterminate="True"
                         Width="200"
                         Height="4"
                         VerticalAlignment="Center" />
        </Border>
    </Grid>
</UserControl>
