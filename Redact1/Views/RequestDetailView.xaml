<UserControl x:Class="Redact1.Views.RequestDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="clr-namespace:Redact1.Converters"
             mc:Ignorable="d"
             Background="{StaticResource SurfaceBrush}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:StatusToDisplayConverter x:Key="StatusToDisplayConverter" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="20,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="Close"
                        Style="{StaticResource IconButton}"
                        Click="CloseButton_Click" />

                <TextBlock Grid.Column="1"
                           Text="{Binding Request.RequestNumber}"
                           FontSize="18"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="16,0,0,0" />

                <Button Grid.Column="2"
                        Content="Save"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding SaveChangesCommand}" />
            </Grid>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" Padding="20">
            <StackPanel>
                <!-- Request Info -->
                <TextBlock Text="Title"
                           FontWeight="Medium"
                           Margin="0,0,0,8" />
                <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource ModernTextBox}"
                         Margin="0,0,0,16" />

                <TextBlock Text="Status"
                           FontWeight="Medium"
                           Margin="0,0,0,8" />
                <ComboBox SelectedValue="{Binding Status}"
                          SelectedValuePath="Tag"
                          Style="{StaticResource ModernComboBox}"
                          Margin="0,0,0,16">
                    <ComboBoxItem Content="New" Tag="new" />
                    <ComboBoxItem Content="In Progress" Tag="in_progress" />
                    <ComboBoxItem Content="Completed" Tag="completed" />
                </ComboBox>

                <TextBlock Text="Notes"
                           FontWeight="Medium"
                           Margin="0,0,0,8" />
                <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource ModernTextBox}"
                         AcceptsReturn="True"
                         Height="100"
                         TextWrapping="Wrap"
                         Margin="0,0,0,24" />

                <!-- Files Section -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Files"
                               FontSize="16"
                               FontWeight="SemiBold" />

                    <Button Grid.Column="1"
                            Content="+ Upload"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding UploadFileCommand}" />
                </Grid>

                <!-- Files List -->
                <ItemsControl ItemsSource="{Binding Files}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="0,0,0,1"
                                    Padding="12"
                                    Cursor="Hand"
                                    MouseLeftButtonUp="FileItem_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <TextBlock Text="{Binding Filename}"
                                                   FontWeight="Medium"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="12">
                                            <Run Text="{Binding FileSizeDisplay}" />
                                            <Run Text=" - " />
                                            <Run Text="{Binding Status, Converter={StaticResource StatusToDisplayConverter}}" />
                                        </TextBlock>
                                    </StackPanel>

                                    <Button Grid.Column="2"
                                            Content="X"
                                            Style="{StaticResource IconButton}"
                                            Foreground="{StaticResource ErrorBrush}"
                                            Command="{Binding DataContext.DeleteFileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Click="DeleteFile_Click" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Upload Progress -->
                <ProgressBar IsIndeterminate="True"
                             Height="4"
                             Margin="0,8,0,0"
                             Visibility="{Binding IsUploading, Converter={StaticResource BoolToVisibilityConverter}}" />

                <!-- Exports Section -->
                <TextBlock Text="Exports"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Margin="0,24,0,16" />

                <Button Content="Create Export"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding CreateExportCommand}"
                        HorizontalAlignment="Left"
                        Margin="0,0,0,16" />

                <ItemsControl ItemsSource="{Binding Exports}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="0,0,0,1"
                                    Padding="12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <TextBlock Text="{Binding Filename}"
                                                   FontWeight="Medium" />
                                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="12">
                                            <Run Text="{Binding FileCount}" />
                                            <Run Text=" files - " />
                                            <Run Text="{Binding CreatedDateTime, StringFormat={}{0:MMM d, yyyy h:mm tt}}" />
                                        </TextBlock>
                                    </StackPanel>

                                    <Button Grid.Column="1"
                                            Content="Download"
                                            Style="{StaticResource SecondaryButton}"
                                            Command="{Binding DataContext.DownloadExportCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Border Grid.RowSpan="2"
                Background="#80FFFFFF"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <ProgressBar IsIndeterminate="True"
                         Width="200"
                         Height="4"
                         VerticalAlignment="Center" />
        </Border>
    </Grid>
</UserControl>
