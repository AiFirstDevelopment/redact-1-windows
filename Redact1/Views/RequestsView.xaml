<UserControl x:Class="Redact1.Views.RequestsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="clr-namespace:Redact1.Converters"
             mc:Ignorable="d"
             Background="{StaticResource BackgroundBrush}">

    <UserControl.Resources>
        <converters:StatusToColorConverter x:Key="StatusToColorConverter" />
        <converters:StatusToBackgroundConverter x:Key="StatusToBackgroundConverter" />
        <converters:StatusToDisplayConverter x:Key="StatusToDisplayConverter" />
        <converters:CountToVisibilityConverter x:Key="CountToVisibilityConverter" />
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="TitleText"
                       Text="Records Requests"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}" />

            <Button x:Name="CreateButton"
                    Grid.Column="1"
                    Content="+ New Request"
                    Style="{StaticResource PrimaryButton}"
                    Click="CreateButton_Click" />
        </Grid>

        <!-- Search and Filter -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox x:Name="SearchBox"
                     Style="{StaticResource ModernTextBox}"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,16,0" />

            <ComboBox x:Name="StatusFilter"
                      Grid.Column="1"
                      Style="{StaticResource ModernComboBox}"
                      SelectedValue="{Binding StatusFilter}"
                      SelectedValuePath="Tag"
                      Width="150">
                <ComboBoxItem Content="All Status" Tag="all" IsSelected="True" />
                <ComboBoxItem Content="New" Tag="new" />
                <ComboBoxItem Content="In Progress" Tag="in_progress" />
                <ComboBoxItem Content="Completed" Tag="completed" />
            </ComboBox>
        </Grid>

        <!-- Loading -->
        <ProgressBar Grid.Row="2"
                     IsIndeterminate="True"
                     Height="4"
                     VerticalAlignment="Top"
                     Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}" />

        <!-- Requests List -->
        <ScrollViewer Grid.Row="2" Margin="0,20,0,0">
            <ItemsControl ItemsSource="{Binding Requests}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource Card}"
                                Margin="0,0,0,12"
                                Cursor="Hand"
                                MouseLeftButtonUp="RequestItem_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- Request Number and Status -->
                                <StackPanel Grid.Column="0" Grid.Row="0" Orientation="Horizontal">
                                    <TextBlock Text="{Binding RequestNumber}"
                                               FontWeight="SemiBold"
                                               FontSize="16"
                                               Foreground="{StaticResource TextPrimaryBrush}" />

                                    <Border Margin="12,0,0,0"
                                            Padding="8,4"
                                            CornerRadius="4"
                                            Background="{Binding Status, Converter={StaticResource StatusToBackgroundConverter}}">
                                        <TextBlock Text="{Binding Status, Converter={StaticResource StatusToDisplayConverter}}"
                                                   FontSize="12"
                                                   Foreground="{Binding Status, Converter={StaticResource StatusToColorConverter}}" />
                                    </Border>
                                </StackPanel>

                                <!-- Date -->
                                <TextBlock Grid.Column="1" Grid.Row="0"
                                           Text="{Binding RequestDateTime, StringFormat={}{0:MMM d, yyyy}}"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center" />

                                <!-- Title -->
                                <TextBlock Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1"
                                           Text="{Binding Title}"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,8,0,0"
                                           TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Empty State -->
        <StackPanel Grid.Row="2"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Visibility="{Binding Requests.Count, Converter={StaticResource CountToVisibilityConverter}}">
            <TextBlock Text="No requests found"
                       FontSize="18"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       HorizontalAlignment="Center" />
            <TextBlock Text="Create a new request to get started"
                       FontSize="14"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,8,0,0" />
        </StackPanel>
    </Grid>
</UserControl>
