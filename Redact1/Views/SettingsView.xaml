<UserControl x:Class="Redact1.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{StaticResource BackgroundBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="Settings"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="{StaticResource TextPrimaryBrush}"
                   Margin="0,0,0,20" />

        <!-- Settings Content -->
        <ScrollViewer Grid.Row="1">
            <StackPanel>
                <!-- Profile Section -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Profile"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,16" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="Name:"
                                       FontWeight="Medium"
                                       Margin="0,0,16,8" />
                            <TextBlock Grid.Row="0" Grid.Column="1"
                                       Text="{Binding CurrentUser.Name}"
                                       Margin="0,0,0,8" />

                            <TextBlock Grid.Row="1" Grid.Column="0"
                                       Text="Email:"
                                       FontWeight="Medium"
                                       Margin="0,0,16,8" />
                            <TextBlock Grid.Row="1" Grid.Column="1"
                                       Text="{Binding CurrentUser.Email}"
                                       Margin="0,0,0,8" />

                            <TextBlock Grid.Row="2" Grid.Column="0"
                                       Text="Role:"
                                       FontWeight="Medium"
                                       Margin="0,0,16,0" />
                            <TextBlock Grid.Row="2" Grid.Column="1"
                                       Text="{Binding CurrentUser.Role}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Account Actions -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Account"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,16" />

                        <Button Content="Sign Out"
                                Style="{StaticResource DangerButton}"
                                Command="{Binding LogoutCommand}"
                                HorizontalAlignment="Left" />
                    </StackPanel>
                </Border>

                <!-- Support Section -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Support"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,16" />

                        <Button Content="Contact Support"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding OpenSupportCommand}"
                                HorizontalAlignment="Left" />
                    </StackPanel>
                </Border>

                <!-- About Section -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="About"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,16" />

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="Version:"
                                       FontWeight="Medium"
                                       Margin="0,0,8,0" />
                            <TextBlock Text="{Binding AppVersion}" />
                        </StackPanel>

                        <TextBlock Text="Redact-1 for Windows"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,8" />

                        <TextBlock Text="Police records redaction system for FOIA requests."
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
