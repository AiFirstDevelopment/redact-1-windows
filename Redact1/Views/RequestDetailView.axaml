<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Redact1.Views.RequestDetailView"
             Background="{StaticResource SurfaceBrush}">

    <UserControl.Styles>
        <!-- Header buttons with soft pastel hover - override all states -->
        <Style Selector="Button.header-btn">
            <Setter Property="Background" Value="#D4B8A8" />
            <Setter Property="Foreground" Value="#3D3632" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.header-btn:pointerover">
            <Setter Property="Background" Value="#E5CFC2" />
        </Style>
        <Style Selector="Button.header-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#E5CFC2" />
            <Setter Property="Foreground" Value="#3D3632" />
        </Style>
        <Style Selector="Button.header-btn:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#C9A999" />
            <Setter Property="Foreground" Value="#3D3632" />
        </Style>

        <Style Selector="Button.header-save">
            <Setter Property="Background" Value="#FAF7F4" />
            <Setter Property="Foreground" Value="#8B5E47" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.header-save:pointerover">
            <Setter Property="Background" Value="White" />
        </Style>
        <Style Selector="Button.header-save:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="#8B5E47" />
        </Style>
        <Style Selector="Button.header-save:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#F0EBE6" />
            <Setter Property="Foreground" Value="#8B5E47" />
        </Style>
    </UserControl.Styles>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header with accent color -->
        <Border Grid.Row="0"
                Background="{StaticResource PrimaryBrush}"
                Padding="20,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="Close"
                        Classes="header-btn"
                        x:Name="CloseButton" />

                <TextBlock Grid.Column="1"
                           Text="{Binding Request.RequestNumber}"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="White"
                           VerticalAlignment="Center"
                           Margin="16,0,0,0" />

                <Button Grid.Column="2"
                        Content="Save"
                        Classes="header-save"
                        Command="{Binding SaveChangesCommand}" />
            </Grid>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" Padding="20">
            <StackPanel>
                <!-- Request Info -->
                <TextBlock Text="Title" FontWeight="Medium" Margin="0,0,0,8" />
                <TextBox Text="{Binding Title}" Classes="modern" Margin="0,0,0,16" />

                <TextBlock Text="Status" FontWeight="Medium" Margin="0,0,0,8" />
                <ComboBox SelectedIndex="0" Margin="0,0,0,16">
                    <ComboBoxItem Content="New" Tag="new" />
                    <ComboBoxItem Content="In Progress" Tag="in_progress" />
                    <ComboBoxItem Content="Completed" Tag="completed" />
                </ComboBox>

                <TextBlock Text="Notes" FontWeight="Medium" Margin="0,0,0,8" />
                <TextBox Text="{Binding Notes}"
                         Classes="modern"
                         AcceptsReturn="True"
                         Height="100"
                         TextWrapping="Wrap"
                         Margin="0,0,0,24" />

                <!-- Files Section -->
                <Border Background="#F5EDE6" CornerRadius="10" Padding="16" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Border Background="{StaticResource PrimaryBrush}" CornerRadius="6" Padding="8,4">
                                <TextBlock Text="FILES" FontSize="11" FontWeight="Bold" Foreground="White" />
                            </Border>
                            <TextBlock Text="{Binding Files.Count}" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Content="+ Upload"
                                Classes="primary"
                                x:Name="UploadButton" />
                    </Grid>
                </Border>

                <!-- Files List -->
                <ItemsControl ItemsSource="{Binding Files}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Classes="list-item" PointerPressed="FileItem_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <TextBlock Text="{Binding Filename}" FontWeight="Medium" />
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding FileSizeDisplay}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" />
                                            <TextBlock Text=" - " Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" />
                                            <TextBlock Text="{Binding Status}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" />
                                        </StackPanel>
                                    </StackPanel>

                                    <Button Grid.Column="1"
                                            Content="X"
                                            Classes="icon"
                                            Foreground="{StaticResource ErrorBrush}"
                                            Command="{Binding $parent[UserControl].DataContext.RequestDeleteFileCommand}"
                                            CommandParameter="{Binding}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Upload Progress -->
                <ProgressBar IsIndeterminate="True"
                             Height="4"
                             Margin="0,8,0,0"
                             IsVisible="{Binding IsUploading}" />

                <!-- Export Button -->
                <Button Content="Export"
                        Background="{StaticResource SuccessBrush}"
                        Foreground="White"
                        FontWeight="SemiBold"
                        CornerRadius="8"
                        Padding="16,10"
                        Margin="0,16,0,0"
                        HorizontalAlignment="Left"
                        Cursor="Hand"
                        Command="{Binding CreateExportCommand}" />

                <!-- Actions Section -->
                <Border Background="#F5EDE0" CornerRadius="10" Padding="16" Margin="0,24,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Border Background="{StaticResource WarningBrush}" CornerRadius="6" Padding="8,4">
                                <TextBlock Text="ACTIONS" FontSize="11" FontWeight="Bold" Foreground="White" />
                            </Border>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Content="Archive"
                                Classes="secondary"
                                Command="{Binding ArchiveRequestCommand}"
                                Margin="0,0,8,0" />

                        <Button Grid.Column="2"
                                Content="Delete"
                                Classes="danger"
                                Command="{Binding RequestDeleteCommand}" />
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Border Grid.RowSpan="2"
                Background="#80FFFFFF"
                IsVisible="{Binding IsLoading}">
            <ProgressBar IsIndeterminate="True" Width="200" Height="4" VerticalAlignment="Center" />
        </Border>

        <!-- Delete File Confirmation Modal -->
        <Border Grid.RowSpan="2"
                Background="#80000000"
                IsVisible="{Binding IsConfirmingFileDelete}">
            <Border Classes="card"
                    Width="400"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Confirm Delete File"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource ErrorBrush}"
                               Margin="0,0,0,16" />

                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,24">
                        <Run Text="Are you sure you want to delete " />
                        <Run Text="{Binding FileToDelete.Filename}" FontWeight="SemiBold" />
                        <Run Text="? This action cannot be undone." />
                    </TextBlock>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Content="Cancel"
                                Classes="secondary"
                                Command="{Binding CancelDeleteFileCommand}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Margin="0,0,8,0" />

                        <Button Grid.Column="1"
                                Content="Delete"
                                Classes="danger"
                                Command="{Binding ConfirmDeleteFileCommand}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Margin="8,0,0,0" />
                    </Grid>
                </StackPanel>
            </Border>
        </Border>

        <!-- Delete Request Confirmation Modal -->
        <Border Grid.RowSpan="2"
                Background="#80000000"
                IsVisible="{Binding IsConfirmingDelete}">
            <Border Classes="card"
                    Width="400"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Confirm Delete"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource ErrorBrush}"
                               Margin="0,0,0,16" />

                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,24">
                        <Run Text="Are you sure you want to delete this request? This action cannot be undone." />
                    </TextBlock>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Content="Cancel"
                                Classes="secondary"
                                Command="{Binding CancelDeleteRequestCommand}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Margin="0,0,8,0" />

                        <Button Grid.Column="1"
                                Content="Delete"
                                Classes="danger"
                                Command="{Binding ConfirmDeleteRequestCommand}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Margin="8,0,0,0" />
                    </Grid>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
