<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Redact1.Views.LoginView"
             Background="{StaticResource BackgroundBrush}">

    <Grid>
        <Border Classes="card"
                Width="400"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">
            <StackPanel>
                <!-- Logo/Title -->
                <TextBlock Text="Redact-1"
                           FontSize="32"
                           FontWeight="Bold"
                           Foreground="{StaticResource PrimaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8" />

                <TextBlock Text="Police Records Redaction System"
                           FontSize="14"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,32" />

                <!-- Error Message -->
                <Border Background="#FED7D7"
                        CornerRadius="6"
                        Padding="12"
                        Margin="0,0,0,16"
                        IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="#C53030"
                               TextWrapping="Wrap" />
                </Border>

                <!-- Email -->
                <TextBlock Text="Email"
                           FontSize="14"
                           FontWeight="Medium"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           Margin="0,0,0,8" />
                <TextBox x:Name="EmailTextBox"
                         Text="{Binding Email}"
                         Classes="modern"
                         Margin="0,0,0,16" />

                <!-- Password -->
                <TextBlock Text="Password"
                           FontSize="14"
                           FontWeight="Medium"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           Margin="0,0,0,8" />
                <TextBox x:Name="PasswordBox"
                         Text="{Binding Password}"
                         PasswordChar="*"
                         Classes="modern"
                         Margin="0,0,0,24" />

                <!-- Login Button -->
                <Button x:Name="LoginButton"
                        Content="Sign In"
                        Classes="primary"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        IsEnabled="{Binding !IsLoading}"
                        Margin="0,0,0,16" />

                <!-- Demo Credentials -->
                <Button Content="Use Demo Credentials"
                        Classes="secondary"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Command="{Binding UseDemoCredentialsCommand}" />

                <!-- Loading Indicator -->
                <ProgressBar IsIndeterminate="True"
                             Height="4"
                             Margin="0,16,0,0"
                             IsVisible="{Binding IsLoading}" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
