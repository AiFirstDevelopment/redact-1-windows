<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Redact1.Views.FileReviewView"
             Background="#1A1A1A">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0"
                Background="{StaticResource PrimaryBrush}"
                Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="Close"
                        Classes="secondary"
                        Background="Transparent"
                        Foreground="White"
                        BorderBrush="White"
                        x:Name="CloseButton" />

                <TextBlock Grid.Column="1"
                           Text="{Binding File.Filename}"
                           Foreground="White"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="Draw Redaction"
                            Classes="secondary"
                            Background="Transparent"
                            Foreground="White"
                            BorderBrush="White"
                            Command="{Binding ToggleDrawingModeCommand}"
                            Margin="0,0,8,0" />

                    <Button Content="Save Redacted"
                            Classes="primary"
                            Background="{StaticResource SuccessBrush}"
                            Command="{Binding SaveRedactedCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- PDF/Image Display -->
        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      Background="#1A1A1A">
            <Grid x:Name="ImageContainer">
                <Image x:Name="DisplayImage"
                       Source="{Binding DisplayImage}"
                       Stretch="Uniform"
                       IsVisible="{Binding !ShowRedacted}" />

                <Image Source="{Binding RedactedImage}"
                       Stretch="Uniform"
                       IsVisible="{Binding ShowRedacted}" />

                <Canvas x:Name="OverlayCanvas"
                        PointerPressed="Canvas_PointerPressed"
                        PointerMoved="Canvas_PointerMoved"
                        PointerReleased="Canvas_PointerReleased" />
            </Grid>
        </ScrollViewer>

        <!-- PDF Navigation -->
        <Border Grid.Row="2"
                Background="{StaticResource SurfaceBrush}"
                Padding="16"
                IsVisible="{Binding File.IsPdf}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="Previous"
                        Classes="secondary"
                        Command="{Binding PreviousPageCommand}"
                        Margin="0,0,16,0" />

                <TextBlock VerticalAlignment="Center">
                    <Run Text="Page " />
                    <Run Text="{Binding CurrentPage}" />
                    <Run Text=" of " />
                    <Run Text="{Binding TotalPages}" />
                </TextBlock>

                <Button Content="Next"
                        Classes="secondary"
                        Command="{Binding NextPageCommand}"
                        Margin="16,0,0,0" />
            </StackPanel>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.RowSpan="3"
                Background="#80000000"
                IsVisible="{Binding IsLoading}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="150" Height="4" />
                <TextBlock Text="Processing..." Foreground="White" Margin="0,12,0,0" HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Detecting Overlay -->
        <Border Grid.RowSpan="3"
                Background="#80000000"
                IsVisible="{Binding IsDetecting}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="150" Height="4" />
                <TextBlock Text="Detecting sensitive content..." Foreground="White" Margin="0,12,0,0" HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
